PORT=3000
# Required by deployment/database commands: development, staging, or production.
DEPLOYMENT_ENV=development
# Set true only after the database has been positively identified as isolated staging.
STAGING_DATABASE_CONFIRMED=false
# Use production only in the deployed backend process.
NODE_ENV=development
# Comma-separated exact browser origins; no paths, wildcards, queries, or credentials.
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173
# Required, random, and at least 32 bytes in production.
SESSION_SECRET=
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=warranty_managers
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=10000
DB_ENABLE_KEEP_ALIVE=false
DB_POOL_MAX_IDLE=10
DB_POOL_IDLE_TIMEOUT_MS=60000
# disabled, required, or verify_identity. Supply the managed-DB CA path when required.
DB_SSL_MODE=disabled
DB_SSL_CA_FILE=
# Set to the exact trusted proxy hop count (for example 1), or false for direct TLS.
TRUST_PROXY=false
ENFORCE_HTTPS=
# Must be an absolute persistent path in production, mounted outside the public web root.
UPLOAD_DIRECTORY=
FRONTEND_BUILD_DIRECTORY=
MAX_UPLOAD_SIZE_BYTES=10485760
JSON_BODY_LIMIT=100kb
SHUTDOWN_TIMEOUT_MS=10000
# Set MULTI_INSTANCE=true only with an implemented shared limiter store.
MULTI_INSTANCE=false
RATE_LIMIT_STORE=memory
# In production, prefer a single external scheduled job using npm run reminders:run.
REMINDER_SCHEDULER_ENABLED=false
# Legacy compatibility only; prefer REMINDER_SCHEDULER_ENABLED.
DISABLE_REMINDER_SCHEDULER=
GEMINI_API_KEY=
GEMINI_INVOICE_MODEL=gemini-3.5-flash
# Optional comma-separated ordered model fallback list; overrides GEMINI_INVOICE_MODEL.
GEMINI_MODELS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Select smtp or https_api. HTTPS API delivery uses a provider API over TLS.
EMAIL_PROVIDER=smtp
HTTPS_EMAIL_API_URL=
HTTPS_EMAIL_API_KEY=
HTTPS_EMAIL_FROM=
EMAIL_HTTPS_TIMEOUT_MS=5000
EMAIL_HTTPS_MAX_RETRIES=1

# Operator tooling. Keep approval values false/blank until each target and operation is confirmed.
BACKUP_FILE=
MYSQL_CLIENT_CONTAINER=
FILE_BACKUP_DIRECTORY=
FILE_RESTORE_DIRECTORY=
RESTORE_DB_NAME=
RESTORE_DATABASE_CONFIRMED=false
MYSQL_ROOT_PASSWORD=
STAGING_BASE_URL=
# Supply only for one approved production database operation; do not persist a real value.
PRODUCTION_CHANGE_APPROVED=
