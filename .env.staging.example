# Copy to .env.staging.local. That local file is ignored by Git.
DEPLOYMENT_ENV=staging
STAGING_DATABASE_CONFIRMED=false
NODE_ENV=production
PORT=3000
FRONTEND_ORIGINS=https://staging.example.invalid
FRONTEND_URL=https://staging.example.invalid
SESSION_SECRET=
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=warranty_manager_staging
DB_USER=warranty_staging_app
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=
DB_CONNECTION_LIMIT=5
DB_CONNECT_TIMEOUT_MS=10000
DB_SSL_MODE=disabled
TRUST_PROXY=false
ENFORCE_HTTPS=false
UPLOAD_DIRECTORY=
MULTI_INSTANCE=false
RATE_LIMIT_STORE=memory
REMINDER_SCHEDULER_ENABLED=false
SMTP_HOST=staging-mail.invalid
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_FROM=Warranty Staging <no-reply@example.invalid>
